{
  "name": "cbr-labs-site",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:apply":       "wrangler d1 execute cbr-labs-db --remote --file=./db/schema.sql",
    "db:apply:local": "wrangler d1 execute cbr-labs-db --local  --file=./db/schema.sql",
    "pages:dev":      "wrangler pages dev out --d1=DB=cbr-labs-db --r2=FILES=cbr-labs-files"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "autoprefixer": "10.4.19",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.10",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "wrangler": "^3.78.0",
    "@cloudflare/workers-types": "^4.20240924.0"
  }
}